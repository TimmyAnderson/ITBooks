//----------------------------------------------------------------------------------------------------------------------
export module ModuleNamespaces;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! Importuje sa LIBRARY.
import <iostream>;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
using namespace std;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! NAMESPACE nie je EXPORTED.
namespace NotExportedNamespace
{
//----------------------------------------------------------------------------------------------------------------------
	// !!! NOT EXPORTED FUNCTION.
	void Print1Internal(int Value)
	{
		wcout << L"PRINT 1 - VALUE [" << Value << L"]." << endl;
	}
//----------------------------------------------------------------------------------------------------------------------
	// !!! EXPORTED FUNCTION.
	export void Print1(int Value)
	{
		Print1Internal(Value);
	}
//----------------------------------------------------------------------------------------------------------------------
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! NAMESPACE je EXPORTED.
export namespace ExportedNamespace
{
//----------------------------------------------------------------------------------------------------------------------
	void Print2(int Value)
	{
		wcout << L"PRINT 2 - VALUE [" << Value << L"]." << endl;
	}
//----------------------------------------------------------------------------------------------------------------------
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! Vykona sa IMPORT ineho MODULE.
import ModuleExportValue1;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
using namespace std;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! CLASS NIE JE EXPORTED.
// !!!!! CLASS pouziva IMPORTED TYPE.
class CNotExportedClass final
{
//----------------------------------------------------------------------------------------------------------------------
	private:
		CMyValue1												MValue;

	public:
		const CMyValue1& GetValue(void) const noexcept;

	public:
		CNotExportedClass(const CMyValue1& Value);
		~CNotExportedClass(void) noexcept;
//----------------------------------------------------------------------------------------------------------------------
};
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
CNotExportedClass::CNotExportedClass(const CMyValue1& Value)
	: MValue(Value)
{
}
//----------------------------------------------------------------------------------------------------------------------
CNotExportedClass::~CNotExportedClass(void) noexcept
{
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
const CMyValue1& CNotExportedClass::GetValue(void) const noexcept
{
	return(MValue);
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! NON-EXPORTED FUNCTION pouziva IMPORTED NOT-EXPORTED TYPE.
CNotExportedClass MyNotExportedTypeFunction1(int Value)
{
	CNotExportedClass											Object(Value);

	return(Object);
}
//----------------------------------------------------------------------------------------------------------------------
// !!! EXPORTED FUNCTION pouziva IMPORTED NOT-EXPORTED TYPE.
export CNotExportedClass MyExportedTypeFunction1(int Value)
{
	CNotExportedClass											Object(Value);

	return(Object);
}

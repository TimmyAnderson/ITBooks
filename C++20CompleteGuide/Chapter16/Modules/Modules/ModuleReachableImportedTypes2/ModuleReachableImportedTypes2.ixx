//----------------------------------------------------------------------------------------------------------------------
// !!! Vykona sa IMPORT ineho MODULE.
import ModuleExportValue2;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
using namespace std;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! CLASS NIE JE EXPORTED.
// !!!!! CLASS pouziva IMPORTED TYPE.
class CNotExportedClass final
{
//----------------------------------------------------------------------------------------------------------------------
	private:
		CMyValue2												MValue;

	public:
		const CMyValue2& GetValue(void) const noexcept;

	public:
		CNotExportedClass(const CMyValue2& Value);
		~CNotExportedClass(void) noexcept;
//----------------------------------------------------------------------------------------------------------------------
};
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
CNotExportedClass::CNotExportedClass(const CMyValue2& Value)
	: MValue(Value)
{
}
//----------------------------------------------------------------------------------------------------------------------
CNotExportedClass::~CNotExportedClass(void) noexcept
{
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
const CMyValue2& CNotExportedClass::GetValue(void) const noexcept
{
	return(MValue);
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! NON-EXPORTED FUNCTION pouziva IMPORTED NOT-EXPORTED TYPE.
CNotExportedClass MyNotExportedTypeFunction2(int Value)
{
	CNotExportedClass											Object(Value);

	return(Object);
}
//----------------------------------------------------------------------------------------------------------------------
// !!! EXPORTED FUNCTION pouziva IMPORTED NOT-EXPORTED TYPE.
export CNotExportedClass MyExportedTypeFunction2(int Value)
{
	CNotExportedClass											Object(Value);

	return(Object);
}

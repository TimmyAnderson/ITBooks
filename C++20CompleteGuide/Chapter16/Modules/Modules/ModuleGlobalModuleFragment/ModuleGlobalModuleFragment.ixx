//----------------------------------------------------------------------------------------------------------------------
// !!! KEYWORD [module] definuje zaciatok FILE, ktory obsahuje MODULE.
module;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! Po KEYWORD [module] mozu nasledovat INCLUDES pre ine pouzivane LIBRARIES.
#include <iostream>
#include <string>
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! KEYWORD [export module] definuje zaciatok samotneho MODULE.
export module ModuleGlobalModuleFragment;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
using namespace std;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
export void PrintString(wstring Value)
{
	wcout << L"VALUE [" << Value << L"]." << endl;
}

//----------------------------------------------------------------------------------------------------------------------
export module ModuleVisibleReachable;
//----------------------------------------------------------------------------------------------------------------------
// !!! NOT EXPORTED CLASS.
class CNotVisibleClass final
{
//----------------------------------------------------------------------------------------------------------------------
	private:
		int														MValue;

	public:
		int GetValue(void) const noexcept;

	public:
		CNotVisibleClass(int Value);
		~CNotVisibleClass(void) noexcept;
//----------------------------------------------------------------------------------------------------------------------
};
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
CNotVisibleClass::CNotVisibleClass(int Value)
	: MValue(Value)
{
}
//----------------------------------------------------------------------------------------------------------------------
CNotVisibleClass::~CNotVisibleClass(void) noexcept
{
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
int CNotVisibleClass::GetValue(void) const noexcept
{
	return(MValue);
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! EXPORTED CLASS.
export class CVisibleClass final
{
//----------------------------------------------------------------------------------------------------------------------
	private:
		CNotVisibleClass										MComplexValue;

	public:
		const CNotVisibleClass& GetComplexValue(void) const noexcept;

	public:
		CVisibleClass(int Value);
		~CVisibleClass(void) noexcept;
//----------------------------------------------------------------------------------------------------------------------
};
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
CVisibleClass::CVisibleClass(int Value)
	: MComplexValue(Value)
{
}
//----------------------------------------------------------------------------------------------------------------------
CVisibleClass::~CVisibleClass(void) noexcept
{
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
const CNotVisibleClass& CVisibleClass::GetComplexValue(void) const noexcept
{
	return(MComplexValue);
}
//----------------------------------------------------------------------------------------------------------------------
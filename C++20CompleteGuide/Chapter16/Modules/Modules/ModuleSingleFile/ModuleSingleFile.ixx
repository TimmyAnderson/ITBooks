//----------------------------------------------------------------------------------------------------------------------
// !!! MODULE je definovany pomocou KEYWORDS [export module].
export module ModuleSingleFile;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! Importuje sa LIBRARY.
import <iostream>;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
using namespace std;
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!! MODULE moze obsahovat CLASSES.
export class CModuleSingleFileValue final
{
//----------------------------------------------------------------------------------------------------------------------
	private:
		int														MValue;

	public:
		int GetValue(void) const noexcept;

	public:
		CModuleSingleFileValue(int Value);
		~CModuleSingleFileValue(void) noexcept;
//----------------------------------------------------------------------------------------------------------------------
};
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
CModuleSingleFileValue::CModuleSingleFileValue(int Value)
	: MValue(Value)
{
}
//----------------------------------------------------------------------------------------------------------------------
CModuleSingleFileValue::~CModuleSingleFileValue(void) noexcept
{
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
int CModuleSingleFileValue::GetValue(void) const noexcept
{
	return(MValue);
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! Kedze METHOD NIE JE EXPORTED, je to INTERNAL METHOD, ktora nie je pristupna vo FILES, ktore importovali tento MODULE.
void InternalPrintInt(int Value)
{
	wcout << L"VALUE [" << Value << L"]." << endl;
}
//----------------------------------------------------------------------------------------------------------------------
// !!!!! METHOD je EXPORTED a teda je pristupna vo FILES, ktore importovali tento MODULE.
export void PrintInt(int Value)
{
	InternalPrintInt(Value);
}
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
//----------------------------------------------------------------------------------------------------------------------
// !!!!! Kedze TEMPLATE FUNCTION NIE JE EXPORTED, je to INTERNAL METHOD, ktora nie je pristupna vo FILES, ktore importovali tento MODULE.
template<typename TType>
void InternalPrint(TType Value)
{
	wcout << L"VALUE [" << Value << L"]." << endl;
}
//----------------------------------------------------------------------------------------------------------------------
// !!!!! TEMPLATE FUNCTION je EXPORTED a teda je pristupna vo FILES, ktore importovali tento MODULE.
export template<typename TType>
void Print(TType Value)
{
	InternalPrint(Value);
}
//----------------------------------------------------------------------------------------------------------------------